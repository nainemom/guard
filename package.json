{
  "name": "guard",
  "private": true,
  "version": "1.3.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:ts": "tsc",
    "build:vite": "vite build",
    "build": "npm run build:ts && npm run build:vite",
    "preview": "vite preview",
    "upload": "gh-pages -d ./dist",
    "lint": "biome check",
    "lint:staged": "biome check --staged --no-errors-on-unmatched",
    "lint:ci": "biome ci",
    "lint:fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest",
    "update:codec-snapshots": "npx tsx ./src/codec/snapshot/generate.ts"
  },
  "dependencies": {
    "@dicebear/collection": "^9.3.2",
    "@dicebear/core": "^9.3.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.5.4",
    "@scure/base": "^2.0.0",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use": "^17.6.0",
    "tailwindcss": "^4.2.1",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "globals": "^17.3.0",
    "lefthook": "^2.1.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
