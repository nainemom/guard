{
  "name": "guard",
  "private": true,
  "version": "1.3.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "upload": "gh-pages -d ./dist",
    "lint": "biome check",
    "lint:staged": "biome check --staged --no-errors-on-unmatched",
    "lint:ci": "biome ci",
    "lint:fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.5.4",
    "framework7": "^9.0.3",
    "framework7-react": "^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use": "^17.6.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
